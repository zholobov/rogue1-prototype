; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Rogue1 Prototype"
run/main_scene="res://src/main.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")

[autoload]

ECS="*uid://dfqwl5njvdnmq"
Config="*res://src/config/game_config.gd"
Net="*res://src/networking/network_manager.gd"
ThemeManager="*res://src/themes/theme_manager.gd"
WeaponRegistry="*res://src/config/weapon_registry.gd"
ModifierRegistry="*res://src/config/modifier_registry.gd"
Elements="*res://src/config/element_registry.gd"
RunManager="*res://src/run/run_manager.gd"
MetaSave="*res://src/run/meta_save.gd"
DamageEvents="*res://src/events/damage_events.gd"

[display]

window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[editor_plugins]

enabled=PackedStringArray("res://addons/gecs/plugin.cfg", "res://addons/gut/plugin.cfg")

